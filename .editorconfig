# EditorConfig — 统一各编辑器的缩进/换行/编码  https://editorconfig.org
root = true

# 默认：UTF-8、LF 换行、文件末尾留空行、去行尾空白、2 空格缩进
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Python（tests/e2e）按 PEP 8 用 4 空格
[*.py]
indent_size = 4

# Markdown 保留行尾空白（两个空格 = 换行语义）
[*.md]
trim_trailing_whitespace = false

# Makefile 之类如有需要用 Tab（当前无，预留）
[Makefile]
indent_style = tab
